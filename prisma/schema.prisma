datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CLIENT
  ADMIN
  PARTNER
}

enum OrderStatus {
  PENDING
  DESIGNING
  REVIEW
  LIVE
  COMPLETED
}

model User {
  id        String   @id @map("_id") @db.String // Clerk User ID
  email     String   @unique
  name      String
  image     String?
  role      Role     @default(CLIENT)
  country   String   @default("PK")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]
  invitations Invitation[]
}

model Order {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  package    String      // e.g. "Premium"
  status     OrderStatus @default(PENDING)
  price      Float
  currency   String      @default("PKR")
  eventDate  DateTime
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String
  slug         String   @unique // e.g. "hadiva.studio/sara-ahmed"
  bride        String
  groom        String
  theme        String   @default("Minimal")
  musicUrl     String?
  venue        String
  venueMapUrl  String?
  countdown    DateTime
  loveStory    Json?    // AI Love story timeline [{title: "Met", body: "..."}]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rsvps RSVP[]
}

model RSVP {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  invitationId String   @db.ObjectId
  guestName    String
  phone        String?
  coming       Boolean
  message      String?
  guestCount   Int      @default(1)
  createdAt    DateTime @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  category  String   // e.g. "Wedding", "Baby Memory"
  thumbnail String   // Cloudinary secure URL
  price     Float
  active    Boolean  @default(true)
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName String
  rating    Int      @default(5)
  comment   String
  createdAt DateTime @default(now())
}
